# TreeXplain Environment Variables

# STAC API Configuration
STAC_API_URL=https://planetarycomputer.microsoft.com/api/stac/v1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Model Configuration
MODEL_PATH=models/deforestation_model_final.pt

# Data Configuration
DATA_DIR=data
MODELS_DIR=models
OUTPUT_DIR=output

# Logging Configuration
LOG_LEVEL=INFO

# Optional: Planetary Computer API Key (if needed)
# PLANETARY_COMPUTER_API_KEY=your_api_key_here

# Optional: Codecov Token for CI
# CODECOV_TOKEN=your_codecov_token_here

# Optional: GitHub Token for API access
# GITHUB_TOKEN=your_github_token_here
